# Studio analytics — base URL of the relay's analytics HTTP endpoint.
# Copy this file to .env and fill in the address.
#
# In production this is the relay's internal analytics port, e.g.:
#   http://localhost:3002    (if relay listens on port 3002, reachable from webapp server)
#   https://relay.zapstore.dev  (if you open the port publicly)
#
# Leave blank to disable the analytics API (studio charts fall back to wave data).
RELAY_ANALYTICS_URL=
