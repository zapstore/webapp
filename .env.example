# Relay v1 JSON analytics (impressions, downloads, metrics).
# Proxied client-side at /api/studio/analytics-http/* — no CORS.
#
# Production: required (e.g. http://127.0.0.1:3336 or your relay's analytics bind URL).
# Local dev: optional — `bun run dev` defaults to http://127.0.0.1:3336 when this is unset.
STUDIO_ANALYTICS_HTTP_URL=
